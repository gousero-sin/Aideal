{
  "name": "goflow-core",
  "version": "1.1.0",
  "description": "Nucleo reutilizavel do GoFlowOS para projetos React com Liquid Glass e loaders",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "style": "./dist/goflow-core.css",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/goflow-core.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && vite build"
  },
  "peerDependencies": {
    "framer-motion": "^12.28.2",
    "lucide-react": "^0.562.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "vite": "^7.3.1"
  }
}
